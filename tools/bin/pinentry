#!/bin/bash
set -e

if [ -n "${DISPLAY}" ] && [ -x /usr/bin/pinentry-fltk ]; then
    exec /usr/bin/pinentry-fltk "$@"
fi

if [ -x /usr/bin/pinentry-tty ]; then
    exec /usr/bin/pinentry-tty "$@"
fi

printf 'pinentry: no supported pinentry backend found\n' >&2
printf 'pinentry: install pinentry-fltk or pinentry-tty\n' >&2
exit 127
