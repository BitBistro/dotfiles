[user]
    signingkey = REDACTED_GPG_KEY
    email = mike@bitbistro.org
	name = Mike Perry
[url "ssh://REDACTED_DOMAIN/"]
    insteadOf = https://REDACTED_DOMAIN/
[diff]
    tool = vimdiff
[commit]
        gpgsign = true
[gpg]
    program = gpg
[core]
	pager = /usr/bin/less -FRiX
	editor = vim
	excludesFile = ~/.gitignore
[branch "master"]
	merge = refs/heads/main
[init]
	defaultBranch = main
[push]
	default = simple
	autoSetupRemote = true
[pull]
	rebase = false
[url "REDACTED_DOMAIN:"]
	insteadOf = https://REDACTED_DOMAIN/
[alias]
	pick = cherry-pick
	graph = log --oneline --graph
	ff = pull --no-commit --ff-only origin
	alias = !git config --global -l | awk -F'.' '/^alias\\./&&!/^alias.alias/ {print \"alias\",$2}'
	mod = !go mod
	orphans = "!git fetch -p; git remote prune origin; git checkout -d; git checkout master; git pull -q; git branch -vv --color=never | sed -nre \"s/^([[:space:]]+)([^[:space:]]+)[[:space:]].*\\[origin[^:]+: gone\\].*/\\2/p\" || echo none >&2"
