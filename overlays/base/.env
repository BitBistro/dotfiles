# This might be sourced by dash, ash, sh, or bash. Careful on syntax sugar
: "${TZ=UTC}"
LANG="C"

addPATH () {
    [ -d "$1" ] || return 0
    if echo "${PATH}" | command grep -Evq "(^|:)$1($|:)" ; then
        PATH="$1:$PATH"
    fi
}
# set PATH so it includes user's private bin if it exists
addPATH "${HOME}/.local/bin"

# For Darwin
addPATH "/usr/local/opt/coreutils/libexec/gnubin"

# For Go
addPATH "/usr/local/go/bin"

# WSL Windows tools (clip.exe, notepad.exe; explorer.exe)
addPATH "/mnt/c/Windows/System32"
addPATH "/mnt/c/Windows"

#keys() {
