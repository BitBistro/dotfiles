#    else
#        echo "Wrong password retrieved" >&2
#        return 1
#    fi
#}

if [ -r /etc/default/locale ]; then
    . /etc/default/locale || true
    if command -v locale >/dev/null; then
        if locale -a | grep -q en_US.utf8; then
            LANG="en_US.utf8"
        fi
    fi
    LC_TIME=C
fi

export TZ LANG LC_TIME
