# Enforce LF line endings for all text files in the repo.
# Combined with core.autocrlf=input (set by 10-git-config.sh on Linux),
# this prevents CRLF from sneaking in on Windows/WSL checkouts.
*.sh        text eol=lf
*.vim       text eol=lf
.vimrc      text eol=lf
.bashrc     text eol=lf
.bash_*     text eol=lf
.profile    text eol=lf
.env        text eol=lf
.env-local  text eol=lf
.inputrc    text eol=lf
.editrc     text eol=lf
.gitignore  text eol=lf
*.conf      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
